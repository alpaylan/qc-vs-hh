{
  "setup_steps": [],
  "build_steps": [
    {
      "Command": {
        "command": "stack",
        "args": [
          "install",
          "--ghc-options=\"-optc-std=c99\"",
          "--no-system-ghc",
          "--local-bin-path",
          "./bin"
        ]
      }
    }
  ],
  "test_steps": [
    {
      "Match": {
        "value": "cross",
        "options": {
          "true": {
            "Command": {
              "command": "./bin/${workload}-sampler",
              "args": [
                "{\"sstrategy\": \"${strategy}\", \"sproperty\": \"${property}\", \"stests\": ${tests}}"
              ],
              "run_at": "${workload_path}"
            }
          },
          "false": {
            "Command": {
              "command": "./bin/${workload}",
              "args": [
                "{\"workload\": \"${workload}\", \"strategy\": \"${strategy}\", \"property\": \"${property}\", \"timeout\": ${timeout}}"
              ],
              "run_at": "${workload_path}"
            }
          }
        }
      }
    }
  ]
}